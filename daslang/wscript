#! /usr/bin/env python
# encoding: utf-8

import os
import glob
import re

PROJECT_NAME = 'daScript'

def options(opt):
    pass

def configure(conf):
    pass

def build(bld):
    base = '../thirdparty/daScript'
    src = '../thirdparty/daScript/src'

    # Replicate CMake generation of module .inc files
    # These files are required by daScript source but generated by CMake.
    # We scan modules directory and replicate the logic to avoid "file not found" errors.
    # Store generated files in build directory instead of source tree
    gen_inc_node = bld.bldnode.make_node('daScript_generated/include')
    gen_inc_dir = gen_inc_node.abspath()
    modules_gen_dir = gen_inc_node.make_node('modules')
    os.makedirs(modules_gen_dir.abspath(), exist_ok=True)

    resolve_inc = modules_gen_dir.make_node('external_resolve.inc').abspath()
    need_inc = modules_gen_dir.make_node('external_need.inc').abspath()
    declare_inc = modules_gen_dir.make_node('external_declare.inc').abspath()
    pull_inc = modules_gen_dir.make_node('external_pull.inc').abspath()

    # Clear existing files
    for f in [resolve_inc, need_inc, declare_inc, pull_inc]:
        with open(f, 'w') as fh:
            fh.write('')

    # Clear existing files
    for f in [resolve_inc, need_inc, declare_inc, pull_inc]:
        with open(f, 'w') as fh:
            fh.write('')

    modules_dir = os.path.join(bld.path.abspath(), base, 'modules')
    if os.path.exists(modules_dir):
        for mod_path in sorted(glob.glob(os.path.join(modules_dir, '*', 'CMakeLists.txt'))):
            mod_name = os.path.basename(os.path.dirname(mod_path))
            with open(mod_path, 'r') as f:
                content = f.read()
                
                # ADD_MODULE_CPP(ClassName)
                for cpp_mod in re.findall(r'ADD_MODULE_CPP\s*\(\s*(\w+)\s*\)', content):
                    with open(need_inc, 'a') as fh: fh.write(f'NEED_MODULE(Module_{cpp_mod});\n')
                    with open(declare_inc, 'a') as fh: fh.write(f'DECLARE_MODULE(Module_{cpp_mod});\n')
                    with open(pull_inc, 'a') as fh: fh.write(f'PULL_MODULE(Module_{cpp_mod});\n')
                
                # ADD_MODULE_DAS(category, subfolder, native)
                for das_mod in re.findall(r'ADD_MODULE_DAS\s*\(\s*(\w+)\s*,\s*(\w+)\s*,\s*(\w+)\s*\)', content):
                    category, subfolder, native = das_mod
                    with open(resolve_inc, 'a') as fh:
                        fh.write(f'NATIVE_MODULE({category}, {subfolder}, {mod_name}, {native});\n')

    # Source files (parser files are already generated and committed in daScript repo)
    das_sources = []
    for subdir in ['parser', 'ast', 'simulate', 'builtin', 'hal', 'misc']:
        pattern = os.path.join(src, subdir, '*.cpp')
        for f in sorted(glob.glob(os.path.join(bld.path.abspath(), pattern))):
            if 'dasFormatter' in f or '${' in f:
                continue
            rel = os.path.relpath(f, bld.path.abspath())
            das_sources.append(rel)
    
    # Add uriparser C sources
    uriparser_src = [
        '../thirdparty/daScript/3rdparty/uriparser/src/UriCommon.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriCompare.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriEscape.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriFile.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriIp4.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriIp4Base.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriNormalize.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriNormalizeBase.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriParse.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriParseBase.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriQuery.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriRecompose.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriResolve.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriShorten.c',
        '../thirdparty/daScript/3rdparty/uriparser/src/UriMemory.c',
    ]
    das_sources.extend(uriparser_src)
    
    # Platform-specific settings
    if bld.env.DEST_OS == 'win32':
        cxxflags = ['/O2', '/std:c++17', '/W3']
        defines = ['DAS_NO_ASSERTIONS', 'URIPARSER_BUILD_CHAR', 'URI_STATIC_BUILD', '_CRT_SECURE_NO_WARNINGS']
        includes = [
            '../thirdparty/daScript/include',
            '../thirdparty/daScript/include/daScript',
            gen_inc_node,
            '../thirdparty/daScript/3rdparty/fmt/include',
            '../thirdparty/daScript/3rdparty/uriparser/include',
        ]
        features = 'c cxx'
    elif bld.env.DEST_OS == 'android':
        cxxflags = ['-frtti', '-O2', '-fPIC', '-std=gnu++17']
        defines = ['DAS_NO_ASSERTIONS', 'URIPARSER_BUILD_CHAR', 'URI_STATIC_BUILD']
        includes = [
            '../thirdparty/daScript/include',
            '../thirdparty/daScript/include/daScript',
            gen_inc_node,
            '../thirdparty/daScript/3rdparty/fmt/include',
            '../thirdparty/daScript/3rdparty/uriparser/include',
        ]
        features = 'c cxx'
    else:  # linux, darwin
        cxxflags = ['-frtti', '-O3', '-fPIC', '-std=gnu++17', '-Wno-invalid-offsetof']
        defines = ['DAS_NO_ASSERTIONS', 'URIPARSER_BUILD_CHAR', 'URI_STATIC_BUILD']
        includes = [
            '../thirdparty/daScript/include',
            '../thirdparty/daScript/include/daScript',
            gen_inc_node,
            '../thirdparty/daScript/3rdparty/fmt/include',
            '../thirdparty/daScript/3rdparty/uriparser/include',
        ]
        features = 'c cxx'
    
    bld.stlib(
        features = features,
        source = das_sources,
        target = PROJECT_NAME,
        name = PROJECT_NAME,
        includes = includes,
        defines = defines,
        cxxflags = cxxflags,
    )
    
    # Install daslib to dascripts/daslib/ during install phase
    if bld.cmd == 'install':
        import shutil
        daslib_src = os.path.join(bld.path.abspath(), base, 'daslib')
        daslib_dst = os.path.join(bld.env.PREFIX, 'dascripts', 'daslib')
        os.makedirs(daslib_dst, exist_ok=True)
        for f in glob.glob(os.path.join(daslib_src, '*.das')):
            shutil.copy2(f, daslib_dst)